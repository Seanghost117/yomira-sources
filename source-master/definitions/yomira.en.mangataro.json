{
  "schemaVersion": "1.0",
  "sourceDefinitionKind": "curated_source_config",
  "id": "yomira.en.mangataro",
  "sourceId": "yomira.en.mangataro",
  "name": "MangaTaro",
  "displayName": "MangaTaro",
  "version": "1.0.0",
  "connectorEngine": "selector",
  "sourceType": "selector",
  "base_url": "https://mangataro.org",
  "baseUrl": "https://mangataro.org",
  "language": "en",
  "region": "en",
  "nsfw": true,
  "adultContent": true,
  "description": "MangaTaro catalog using the site's public REST catalog endpoint for stable search, latest, popular, release, and alphabetical sections.",
  "tags": ["Yomira", "Selector", "Manga", "Manhwa", "Collections"],
  "appStoreSafe": true,
  "containsExecutableCode": false,
  "requiresExternalBridge": false,
  "rate_limit_ms": 1100,
  "rateLimit": {
    "minDelayMs": 1100,
    "requestsPerMinute": 50
  },
  "endpoints": {
    "search": {
      "url": "{base}/wp-json/manga/v1/load",
      "method": "POST",
      "content_type": "application/json",
      "body": "{\"page\":{page},\"search\":\"{query}\",\"years\":\"[]\",\"genres\":\"[]\",\"types\":\"[]\",\"statuses\":\"[]\",\"sort\":\"post_desc\",\"genreMatchMode\":\"any\"}"
    },
    "popular": {
      "url": "{base}/wp-json/manga/v1/load",
      "method": "POST",
      "content_type": "application/json",
      "body": "{\"page\":{page},\"search\":\"\",\"years\":\"[]\",\"genres\":\"[]\",\"types\":\"[]\",\"statuses\":\"[]\",\"sort\":\"popular_desc\",\"genreMatchMode\":\"any\"}"
    },
    "latest": {
      "url": "{base}/wp-json/manga/v1/load",
      "method": "POST",
      "content_type": "application/json",
      "body": "{\"page\":{page},\"search\":\"\",\"years\":\"[]\",\"genres\":\"[]\",\"types\":\"[]\",\"statuses\":\"[]\",\"sort\":\"post_desc\",\"genreMatchMode\":\"any\"}"
    },
    "recently_released": {
      "url": "{base}/wp-json/manga/v1/load",
      "method": "POST",
      "content_type": "application/json",
      "body": "{\"page\":{page},\"search\":\"\",\"years\":\"[]\",\"genres\":\"[]\",\"types\":\"[]\",\"statuses\":\"[]\",\"sort\":\"release_desc\",\"genreMatchMode\":\"any\"}"
    },
    "title_az": {
      "url": "{base}/wp-json/manga/v1/load",
      "method": "POST",
      "content_type": "application/json",
      "body": "{\"page\":{page},\"search\":\"\",\"years\":\"[]\",\"genres\":\"[]\",\"types\":\"[]\",\"statuses\":\"[]\",\"sort\":\"title_asc\",\"genreMatchMode\":\"any\"}"
    },
    "details": { "url": "{base}/manga/{id}", "method": "GET" },
    "chapters": { "url": "{base}/manga/{id}", "method": "GET" },
    "pages": { "url": "{chapter_url}", "method": "GET" }
  },
  "selectors": {
    "manga_list": {
      "container": "a[href*='/manga/']:has(img) || .manga-card || .manga-item",
      "title": "h3@text || .manga-title@text || img@alt || @title",
      "cover": "img@data-src || img@src",
      "link": "@href || a@href"
    },
    "manga_details": {
      "title": "h1@text || meta[property='og:title']@content",
      "cover": "meta[property='og:image']@content || img[src*='/content/media/']@src",
      "description": "meta[name='description']@content || .description@text || .summary@text",
      "authors": "a[href*='/author/']@text",
      "artists": "a[href*='/artist/']@text",
      "genres": "a[href*='/tag/']@text",
      "status": "a[href*='/status/']@text || .status@text"
    },
    "chapter_list": {
      "container": "a[href*='/read/'] || .chapter-list a",
      "title": "@text || a@text",
      "link": "@href || a@href",
      "date": "time@datetime || .date@text",
      "number_regex": "(?i)(?:chapter|ch\\.?)[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)"
    },
    "page_list": {
      "container": "body",
      "image": "img[data-src*='/content/media/']@data-src || img[src*='/content/media/']@src || img@data-src || img@src",
      "exclude": ["logo", "icon", "avatar", "favicon"]
    }
  },
  "presentation": {
    "primaryListing": "popular",
    "sections": [
      "popular",
      "latest",
      "recently_released",
      "title_az"
    ],
    "listingLabels": {
      "popular": "Most Popular MangaTaro Titles",
      "latest": "Latest MangaTaro Updates",
      "recently_released": "Recently Released MangaTaro Titles",
      "title_az": "MangaTaro A-Z"
    },
    "listingSubtitles": {
      "recently_released": "Sorted by the release date exposed by MangaTaro",
      "title_az": "Alphabetical catalog browsing"
    },
    "listingStyles": {
      "popular": "carousel",
      "latest": "list",
      "recently_released": "carousel",
      "title_az": "grid"
    }
  },
  "provenance": {
    "ecosystem": "yomira",
    "originalFamily": "Selector",
    "originalLanguage": "en",
    "originalSourceName": "MangaTaro",
    "analyzerBucket": "curated_selector_profile"
  }
}

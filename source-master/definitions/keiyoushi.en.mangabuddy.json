{
  "schemaVersion": "1.0",
  "sourceDefinitionKind": "curated_source_config",
  "id": "keiyoushi.en.mangabuddy",
  "sourceId": "keiyoushi.en.mangabuddy",
  "name": "MangaBuddy",
  "displayName": "MangaBuddy",
  "version": "1.2.0",
  "connectorEngine": "selector",
  "sourceType": "selector",
  "base_url": "https://mangak.io",
  "baseUrl": "https://mangak.io",
  "language": "en",
  "region": "en",
  "nsfw": false,
  "adultContent": false,
  "description": "MangaBuddy source definition normalized to its current MangaK/Next.js reader flow.",
  "tags": [
    "Keiyoushi",
    "Selector",
    "Curated"
  ],
  "appStoreSafe": true,
  "containsExecutableCode": false,
  "requiresExternalBridge": false,
  "flags": {
    "is_madara": false,
    "requires_js": false,
    "uses_cloudflare": false
  },
  "rate_limit_ms": 1000,
  "rateLimit": {
    "minDelayMs": 1000,
    "requestsPerMinute": 60
  },
  "endpoints": {
    "search": {
      "url": "{base}/search?q={query}",
      "method": "GET"
    },
    "popular": {
      "url": "{base}/top/day",
      "method": "GET"
    },
    "latest": {
      "url": "{base}/latest",
      "method": "GET"
    },
    "trending": {
      "url": "{base}/trending/manga",
      "method": "GET"
    },
    "hot_week": {
      "url": "{base}/home",
      "method": "GET"
    },
    "ranking": {
      "url": "{base}/ranking",
      "method": "GET"
    },
    "details": {
      "url": "{base}/{id}",
      "method": "GET"
    },
    "chapters": {
      "url": "{base}/{id}",
      "method": "GET"
    },
    "pages": {
      "url": "{chapter_url}",
      "method": "GET"
    }
  },
  "selectors": {
    "manga_list": {
      "container": ".book-item || a[href^='/'][aria-label] || a[href^='/']:has(img)",
      "title": ".title h3 a@title || .title h3 a@text || .thumb a@title || @aria-label || img@alt",
      "cover": ".thumb img@data-src || .thumb img@src || img@src || img@data-src",
      "link": ".title h3 a@href || .thumb a@href || @href"
    },
    "manga_details": {
      "title": "h1@text || meta[property='og:title']@content",
      "cover": "meta[property='og:image']@content",
      "description": "meta[name='description']@content || meta[property='og:description']@content",
      "authors": "a[href*='/authors/']@text",
      "genres": "a[href*='/genres/']@text",
      "status": ".status-pill@text"
    },
    "chapter_list": {
      "container": ".__yomira-next-data-fallback",
      "title": "a@text",
      "link": "a@href",
      "date": "time@datetime",
      "number_regex": "(?i)chapter[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)"
    },
    "page_list": {
      "container": ".__yomira-next-data-fallback",
      "image": "img@src",
      "exclude": [
        "logo",
        "icon",
        "avatar"
      ]
    }
  },
  "headers": {
    "Referer": "https://mangak.io/"
  },
  "presentation": {
    "primaryListing": "hot_week",
    "sections": [
      "hot_week",
      "latest",
      "trending",
      "popular",
      "ranking"
    ],
    "listingLabels": {
      "hot_week": "Hot This Week",
      "latest": "Recently Updated",
      "trending": "Trending MangaK Titles",
      "popular": "Popular MangaK Titles",
      "ranking": "MangaK Ranking"
    },
    "listingSubtitles": {
      "hot_week": "Weekly highlights from MangaK",
      "latest": "Fresh chapter updates from MangaK",
      "trending": "Titles gaining activity now",
      "popular": "Popular MangaK titles by day",
      "ranking": "Ranked titles from MangaK"
    },
    "listingIcons": {
      "hot_week": "flame.fill",
      "latest": "clock.fill",
      "trending": "chart.line.uptrend.xyaxis",
      "popular": "star.fill",
      "ranking": "number"
    },
    "listingStyles": {
      "hot_week": "featured",
      "latest": "list",
      "trending": "carousel",
      "popular": "carousel",
      "ranking": "list"
    }
  },
  "provenance": {
    "ecosystem": "keiyoushi",
    "originalSourcePath": "src/en/mangabuddy",
    "originalFamily": "MadTheme",
    "originalLanguage": "en",
    "originalSourceName": "mangabuddy",
    "originalExtClass": ".MangaBuddy",
    "analyzerBucket": "curated_selector_profile"
  }
}

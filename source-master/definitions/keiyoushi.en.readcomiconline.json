    {
      "name": "Excluded Genres",
      "param": "eg",
      "field": "excluded_genre",
      "filter_type": "select",
      "options": [
        { "label": "Mature", "value": "8" },
        { "label": "Horror", "value": "15" },
        { "label": "Thriller", "value": "18" },
        { "label": "Vampires", "value": "34" },
        { "label": "Zombies", "value": "36" }
      ]
    },
    {

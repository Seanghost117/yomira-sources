{
  "schemaVersion": "1.0",
  "sourceDefinitionKind": "curated_source_config",
  "id": "keiyoushi.en.readcomiconline",
  "sourceId": "keiyoushi.en.readcomiconline",
  "name": "ReadComicOnline",
  "displayName": "ReadComicOnline",
  "version": "1.0.0",
  "connectorEngine": "selector",
  "sourceType": "selector",
  "base_url": "https://readcomiconline.li",
  "baseUrl": "https://readcomiconline.li",
  "language": "en",
  "region": "en",
  "nsfw": false,
  "adultContent": false,
  "description": "English comics catalog with advanced genre, status, and year filters. Browser Verification is required before browsing or reading.",
  "tags": [
    "Keiyoushi",
    "Comics",
    "Manga",
    "Selector",
    "Curated"
  ],
  "appStoreSafe": true,
  "containsExecutableCode": false,
  "requiresExternalBridge": false,
  "browserVerificationRequired": true,
  "sourceSessionRequired": true,
  "verificationUrl": "https://readcomiconline.li",
  "sessionScopeDomain": "readcomiconline.li",
  "userAgentPolicy": "browser_session",
  "flags": {
    "browserVerificationRequired": true,
    "sourceSessionRequired": true,
    "is_madara": false,
    "requires_js": false,
    "uses_cloudflare": true
  },
  "rate_limit_ms": 1200,
  "rateLimit": {
    "minDelayMs": 1200,
    "requestsPerMinute": 45
  },
  "endpoints": {
    "search": {
      "url": "{base}/AdvanceSearch?comicName={query}&page={page}",
      "method": "GET"
    },
    "popular": {
      "url": "{base}/ComicList/MostPopular?page={page}",
      "method": "GET"
    },
    "latest": {
      "url": "{base}/ComicList/LatestUpdate?page={page}",
      "method": "GET"
    },
    "details": {
      "url": "{base}/{id}",
      "method": "GET"
    },
    "chapters": {
      "url": "{base}/{id}",
      "method": "GET"
    },
    "pages": {
      "url": "{chapter_url}?s=&quality=hq&readType=1",
      "method": "GET"
    }
  },
  "selectors": {
    "manga_list": {
      "container": ".list-comic > .item",
      "title": "a:first-child@text || a:first-child@title",
      "cover": "a:first-child img@src || a:first-child img@data-src || img@src",
      "link": "a:first-child@href || a@href"
    },
    "manga_details": {
      "title": "div.barContent a.bigChar@text || a.bigChar@text || h1@text",
      "cover": ".rightBox img@src || .rightBox img@data-src",
      "description": "p:contains('Summary:')@text || div.barContent p@text",
      "authors": "p:contains('Writer:') a@text",
      "artists": "p:contains('Artist:') a@text",
      "genres": "p:contains('Genres:') a@text",
      "status": "p:contains('Status:')@text"
    },
    "chapter_list": {
      "container": "table.listing tr",
      "title": "a@text",
      "link": "a@href",
      "date": "td@text",
      "number_regex": "(?i)(?:chapter|issue|#)[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)"
    },
    "page_list": {
      "container": "body",
      "image": "img@data-src || img@src",
      "exclude": [
        "logo",
        "avatar",
        "icon",
        "ads"
      ]
    }
  },
  "filters": [
    {
      "name": "Genres & Tags",
      "param": "ig",
      "field": "genre",
      "filter_type": "select",
      "options": [
        { "label": "Action", "value": "1" },
        { "label": "Adventure", "value": "2" },
        { "label": "Anthology", "value": "38" },
        { "label": "Anthropomorphic", "value": "46" },
        { "label": "Biography", "value": "41" },
        { "label": "Children", "value": "49" },

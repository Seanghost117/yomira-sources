      ]
    }
  ],
  "headers": {
    "Referer": "https://readcomiconline.li/"
  },
  "pagination": {
    "param": "page",
    "start": 1
  },
  "presentation": {
    "latestLabel": "Latest Updates",
    "latestStyle": "sliding_list",
    "popularLabel": "Most Popular",

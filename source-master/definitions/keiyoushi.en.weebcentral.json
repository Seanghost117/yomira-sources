{
  "schemaVersion": "1.0",
  "sourceDefinitionKind": "curated_source_config",
  "id": "keiyoushi.en.weebcentral",
  "sourceId": "keiyoushi.en.weebcentral",
  "name": "Weeb Central",
  "displayName": "Weeb Central",
  "version": "1.0.0",
  "connectorEngine": "selector",
  "sourceType": "selector",
  "base_url": "https://weebcentral.com",
  "baseUrl": "https://weebcentral.com",
  "language": "en",
  "region": "en",
  "nsfw": true,
  "adultContent": true,
  "description": "Selector source definition normalized from the current Keiyoushi Weeb Central HttpSource metadata.",
  "tags": [
    "Keiyoushi",
    "Selector",
    "Curated"
  ],
  "appStoreSafe": true,
  "containsExecutableCode": false,
  "requiresExternalBridge": false,
  "browserVerificationRequired": true,
  "sourceSessionRequired": true,
  "verificationUrl": "https://weebcentral.com",
  "sessionScopeDomain": "weebcentral.com",
  "flags": {
    "is_madara": false,
    "requires_js": false,
    "uses_cloudflare": true,
    "browserVerificationRequired": true,
    "sourceSessionRequired": true
  },
  "rate_limit_ms": 1000,
  "rateLimit": {
    "minDelayMs": 1000,
    "requestsPerMinute": 60
  },
  "endpoints": {
    "search": {
      "url": "{base}/search/data?text={query}&sort=Best+Match&order=Ascending&official=Any&display_mode=Full+Display&limit=32&offset=0",
      "method": "GET"
    },
    "popular": {
      "url": "{base}/search/data?sort=Popularity&order=Descending&official=Any&display_mode=Full+Display&limit=32&offset=0",
      "method": "GET"
    },
    "latest": {
      "url": "{base}/search/data?sort=Latest+Updates&order=Descending&official=Any&display_mode=Full+Display&limit=32&offset=0",
      "method": "GET"
    },
    "details": {
      "url": "{base}/series/{id}",
      "method": "GET"
    },
    "chapters": {
      "url": "{base}/series/{id}/full-chapter-list",
      "method": "GET"
    },
    "pages": {
      "url": "{chapter_url}/images?is_prev=False&reading_style=long_strip",
      "method": "GET"
    }
  },
  "selectors": {
    "manga_list": {
      "container": "article > section > a",
      "title": "div:not([class]):last-child@text || @text",
      "cover": "source@srcset || img@src",
      "link": "@href"
    },
    "manga_details": {
      "title": "h1@text",
      "cover": "source@srcset || img@src",
      "description": "li:contains('Description')@text",
      "authors": "li:contains('Author') a@text",
      "genres": "li:contains('Tag') a@text || li:contains('Type') a@text",
      "status": "li:contains('Status') a@text || li:contains('Status') span@text"
    },
    "chapter_list": {
      "container": "div[x-data] > a",
      "title": "span.flex > span@text || @text",
      "link": "@href",
      "date": "time[datetime]@datetime",
      "number_regex": "(?i)(?:chapter|ch\\.?)[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)"
    },
    "page_list": {
      "container": "section[x-data~=scroll]",
      "image": "img@src",
      "exclude": [
        ".svg",
        "logo",
        "icon",
        "avatar",
        "blank"
      ]
    }
  },
  "headers": {
    "Accept": "image/avif,image/webp,*/*",
    "Referer": "https://weebcentral.com/"
  },
  "pagination": {
    "param": "offset",
    "start": 0
  },
  "provenance": {
    "ecosystem": "keiyoushi",
    "originalSourcePath": "src/en/weebcentral",
    "originalFamily": "HttpSource",
    "originalLanguage": "en",
    "originalSourceName": "weebcentral",
    "originalVersion": "21",
    "originalExtClass": ".WeebCentral",
    "analyzerBucket": "curated_selector_profile"
  }
}

{
  "schemaVersion": "1.0",
  "sourceDefinitionKind": "curated_source_config",
  "id": "keiyoushi.en.mangaball",
  "sourceId": "keiyoushi.en.mangaball",
  "name": "MangaBall",
  "displayName": "MangaBall",
  "version": "1.0.0",
  "connectorEngine": "selector",
  "sourceType": "selector",
  "base_url": "https://mangaball.net",
  "baseUrl": "https://mangaball.net",
  "language": "en",
  "region": "en",
  "nsfw": true,
  "adultContent": true,
  "description": "MangaBall catalog normalized from local Keiyoushi API hints. Browser Verification is required because direct HTTP currently returns a Cloudflare challenge; listings use rendered session pages instead of stale unauthenticated API routes.",
  "tags": ["Keiyoushi", "Selector", "Manga", "Manhwa", "NSFW"],
  "appStoreSafe": true,
  "containsExecutableCode": false,
  "requiresExternalBridge": false,
  "browserVerificationRequired": true,
  "sourceSessionRequired": true,
  "verificationUrl": "https://mangaball.net",
  "sessionScopeDomain": "mangaball.net",
  "userAgentPolicy": "browser_session",
  "flags": {
    "browserVerificationRequired": true,
    "sourceSessionRequired": true,
    "uses_cloudflare": true
  },
  "rate_limit_ms": 1300,
  "rateLimit": {
    "minDelayMs": 1300,
    "requestsPerMinute": 40
  },
  "endpoints": {
    "search": { "url": "{base}/search-advanced?search_input={query}&page={page}", "method": "GET" },
    "popular": { "url": "{base}/", "method": "GET" },
    "latest": { "url": "{base}/recently-updated-chapter/?page={page}", "method": "GET" },
    "recommended": { "url": "{base}/", "method": "GET" },
    "popular_this_season": { "url": "{base}/", "method": "GET" },
    "top_viewed": { "url": "{base}/", "method": "GET" },
    "highlighted": { "url": "{base}/", "method": "GET" },
    "details": { "url": "{base}/title-detail/{id}/", "method": "GET" },
    "chapters": { "url": "{base}/api/v1/chapter/chapter-listing-by-title-id/?title_id={id}", "method": "GET" },
    "pages": { "url": "{chapter_url}", "method": "GET" }
  },
  "selectors": {
    "manga_list": {
      "container": ".slider-item || .grid-item-new-chapter || .table-item-new-chapter || .slider-items-table-item || .list-with-tags-item || a[href*='/title-detail/']:has(img)",
      "title": ".slider-item-title@text || .chapter-title@text || h3@text || h6@text || img@alt || @title",
      "cover": "img.featured-cover@src || img@data-src || img@src",
      "link": "@href || a@href || .chapter-title@href"
    },
    "manga_details": {
      "title": "#comicDetail h6@text || h1@text || meta[property='og:title']@content",
      "cover": "img.featured-cover@src || meta[property='og:image']@content",
      "description": "#descriptionContent p@text || meta[name='description']@content",
      "authors": "#comicDetail span[data-person-id]@text || a[href*='/author/']@text",
      "genres": "#comicDetail span[data-tag-id]@text || a[href*='/tag/']@text",
      "status": "span.badge-status@text || #comicDetail span.badge@text"
    },
    "chapter_list": {
      "container": ".yomira-json-chapter-fallback || .chapter-list a || a[href*='/chapter-detail/']",
      "title": "a@text || @text",
      "link": "a@href || @href",
      "number_regex": "(?i)(?:chapter|ch\\.?)[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)"
    },
    "page_list": {
      "container": "body",
      "image": "img@data-src || img@src",
      "exclude": ["logo", "icon", "avatar"]
    }
  },
  "presentation": {
    "primaryListing": "highlighted",
    "sections": ["highlighted", "latest", "popular", "recommended", "popular_this_season", "top_viewed"],
    "listingLabels": {
      "highlighted": "MangaBall Highlights",
      "latest": "Latest MangaBall Updates",
      "popular": "Popular MangaBall Titles",
      "recommended": "Recommended MangaBall Titles",
      "popular_this_season": "Popular This Season",
      "top_viewed": "Top Viewed MangaBall Titles"
    },
    "listingStyles": {
      "highlighted": "featured",
      "latest": "list",
      "popular": "carousel",
      "recommended": "carousel",
      "popular_this_season": "carousel",
      "top_viewed": "carousel"
    }
  },
  "provenance": {
    "ecosystem": "keiyoushi",
    "originalFamily": "HttpSource",
    "originalLanguage": "en",
    "originalSourceName": "MangaBall",
    "analyzerBucket": "curated_selector_profile"
  }
}

{
  "id": "allmanga",
  "name": "AllManga",
  "version": "1.0.0",
  "base_url": "https://allmanga.to",
  "language": "en",
  "nsfw": false,
  "description": "Multi-media platform with manga, anime, and community features",
  "tags": ["Manga", "Manhwa", "Manhua", "Aggregator", "Free"],
  "flags": {
    "is_madara": false,
    "requires_js": true,
    "uses_cloudflare": false
  },
  "endpoints": {
    "search": {
      "url": "{base}/search-manga?search={query}&cty=ALL",
      "method": "GET"
    },
    "popular": {
      "url": "{base}/manga?cty=ALL",
      "method": "GET"
    },
    "latest": {
      "url": "{base}/search-manga?cty=ALL",
      "method": "GET"
    },
    "details": {
      "url": "{base}/manga/{id}",
      "method": "GET"
    },
    "chapters": {
      "url": "{base}/manga/{id}",
      "method": "GET"
    },
    "pages": {
      "url": "{chapter_url}",
      "method": "GET"
    }
  },
  "selectors": {
    "manga_list": {
      "container": ".manga-card, .cardContainer, .card, .item",
      "title": "a@title || .title@text || h3@text",
      "cover": "img@src || img@data-src",
      "link": "a@href"
    },
    "manga_details": {
      "title": "h1@text || .manga-title@text",
      "cover": ".manga-cover img@src || .poster img@src",
      "description": ".description@text || .synopsis@text",
      "authors": ".info:contains('Author') a@text",
      "genres": ".genre a@text || .tags a@text",
      "status": ".info:contains('Status') span@text"
    },
    "chapter_list": {
      "container": ".chapter-list a, .chapters-list a",
      "title": "span@text || @text",
      "link": "@href",
      "date": ".date@text || time@datetime",
      "number_regex": "(?i)chapter[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)"
    },
    "page_list": {
      "container": ".reader, .chapter-reader",
      "image": "img@src || img@data-src",
      "exclude": [".svg", "data:", "logo", "icon", "avatar", "blank"]
    }
  },
  "headers": {
    "Referer": "https://allmanga.to/"
  },
  "pagination": {
    "param": "page",
    "start": 1
  },
  "_note": "SPA-rendered site (requires JS). Also hosts anime."
}

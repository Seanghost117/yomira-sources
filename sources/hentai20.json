{
  "id": "hentai20",
  "name": "Hentai20",
  "version": "1.2.0",
  "base_url": "https://hentai20.io",
  "language": "en",
  "nsfw": true,
  "description": "Adult manhwa, manga, and webtoons with English translations",
  "tags": ["Manhwa", "Webtoon", "NSFW", "Hentai"],
  "flags": {
    "is_madara": false,
    "requires_js": false,
    "uses_cloudflare": true
  },
  "endpoints": {
    "search": {
      "url": "{base}/?s={query}",
      "method": "GET"
    },
    "popular": {
      "url": "{base}/manga/?status=&type=&order=popular",
      "method": "GET"
    },
    "latest": {
      "url": "{base}/manga/?status=&type=&order=update",
      "method": "GET"
    },
    "details": {
      "url": "{base}/manga/{id}/",
      "method": "GET"
    },
    "chapters": {
      "url": "{base}/manga/{id}/",
      "method": "GET"
    },
    "pages": {
      "url": "{chapter_url}",
      "method": "GET"
    }
  },
  "selectors": {
    "manga_list": {
      "container": ".bsx",
      "title": "a@title || .tt@text",
      "cover": "img@src || img@data-src",
      "link": "a@href"
    },
    "manga_details": {
      "title": "h1.entry-title@text || .seriestuhead h1@text",
      "cover": ".seriestucontent img@src || .seriestucontent img@data-src",
      "description": ".entry-content p@text || .wd-full p@text",
      "authors": ".imptdt:contains('Author') i@text || .fmed i@text",
      "genres": ".mgen a@text",
      "status": ".imptdt:contains('Status') i@text"
    },
    "chapter_list": {
      "container": "#chapterlist li",
      "title": ".chapternum@text || a@text",
      "link": "a@href",
      "date": ".chapterdate@text",
      "number_regex": "(?i)chapter[\\s/\\-_]*([0-9]+(?:\\.[0-9]+)?)|([0-9]+(?:\\.[0-9]+)?)\\s*$"
    },
    "page_list": {
      "container": "#readerarea",
      "image": "img@src || img@data-src || img@data-lazy-src",
      "exclude": [".svg", "data:", "logo", "icon", "avatar"]
    }
  },
  "pagination": {
    "param": "page",
    "start": 1
  }
}
